{
  "name": "inngest-agent-example",
  "version": "0.1.0",
  "description": "A durable AI agent built with Inngest + pi-ai — think/act/observe loop, Telegram integration, local development via connect()",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "INNGEST_DEV=1 node --watch --env-file=.env --experimental-strip-types --experimental-transform-types --no-warnings src/worker.ts",
    "start": "node --env-file=.env --experimental-strip-types --experimental-transform-types --no-warnings src/worker.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "eval": "AGENT_WORKSPACE=./workspace-evals node --env-file=.env.evals --experimental-strip-types --experimental-transform-types --no-warnings evals/delegation.ts",
    "sidecar": "node --env-file=.env --experimental-strip-types --experimental-transform-types --no-warnings src/sidecar/sidecar.ts",
    "sidecar:dev": "INNGEST_DEV=1 node --watch --env-file=.env --experimental-strip-types --experimental-transform-types --no-warnings src/sidecar/sidecar.ts",
    "tui": "node --env-file=.env --experimental-strip-types --experimental-transform-types --no-warnings src/tui/index.ts",
    "tui:dev": "INNGEST_DEV=1 node --env-file=.env --experimental-strip-types --experimental-transform-types --no-warnings src/tui/index.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@mariozechner/pi-agent-core": "^0.73.1",
    "@mariozechner/pi-ai": "^0.73.1",
    "@mariozechner/pi-coding-agent": "^0.73.1",
    "@sinclair/typebox": "^0.34.0",
    "inngest": "4.7.0",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.2.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{ts,js,json,md}": "prettier --write"
  },
  "engines": {
    "node": ">=23.0.0",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.18.2+sha512.9fb969fa749b3ade6035e0f109f0b8a60b5d08a1a87fdf72e337da90dcc93336e2280ca4e44f2358a649b83c17959e9993e777c2080879f3801e6f0d999ad3dd"
}
